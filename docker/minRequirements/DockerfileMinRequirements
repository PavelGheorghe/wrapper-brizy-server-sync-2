FROM ubuntu:latest

RUN set -eux; \
	apt-get update;

ENV DEBIAN_FRONTEND=noninteractive

RUN apt -y install software-properties-common;
RUN add-apt-repository ppa:ondrej/development;
RUN apt-get update;
RUN apt install -y php7.4 && \
    echo "8\n8";

RUN apt install -y php7.4-xml;


COPY . /var/www/html
COPY ./docker/minRequirements/apache.conf /etc/apache2/sites-available/000-default.conf

CMD apachectl -D FOREGROUND





